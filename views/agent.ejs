<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>CreateAgent - Divine Create</title>
  <link rel="stylesheet" href="/styles.css">
  <style>
    .agent-wrapper {
      display: grid;
      grid-template-columns: 1fr 350px;
      gap: 14px;
      margin-top: 20px;
      height: calc(100vh - 300px);
      min-height: 500px;
    }
    .chat-area {
      border: 1px solid rgba(255,255,255,0.10);
      border-radius: 16px;
      background: rgba(0,0,0,0.22);
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }
    .chat-messages {
      flex: 1;
      overflow-y: auto;
      padding: 18px;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .message {
      padding: 12px 16px;
      border-radius: 12px;
      max-width: 80%;
      word-wrap: break-word;
    }
    .message.user {
      background: rgba(255,215,0,0.15);
      color: rgba(255,215,0,0.92);
      align-self: flex-end;
      border: 1px solid rgba(255,215,0,0.25);
      font-weight: 900;
    }
    .message.agent {
      background: rgba(79,176,229,0.12);
      color: var(--text);
      align-self: flex-start;
      border: 1px solid rgba(79,176,229,0.25);
      font-weight: 900;
    }
    .chat-input-area {
      padding: 14px;
      border-top: 1px solid rgba(255,255,255,0.10);
      display: flex;
      gap: 10px;
    }
    .chat-input {
      flex: 1;
      padding: 10px 14px;
      border-radius: 10px;
      border: 1px solid rgba(255,255,255,0.12);
      background: rgba(0,0,0,0.30);
      color: #fff;
      font-weight: 900;
      outline: none;
    }
    .chat-input:focus {
      border-color: rgba(255,215,0,0.25);
      box-shadow: 0 0 0 4px rgba(255,215,0,0.10);
    }
    .chat-send {
      padding: 10px 14px;
      border-radius: 10px;
      border: none;
      background: linear-gradient(135deg, #ffd24a 12%, #a34bff 55%, #6d2bd6 100%);
      color: #140b1f;
      font-weight: 1000;
      cursor: pointer;
      transition: all .16s ease;
    }
    .chat-send:hover {
      transform: translateY(-2px);
      box-shadow: 0 12px 30px rgba(163,75,255,0.25);
    }
    .sidebar {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .model-selector {
      border: 1px solid rgba(255,255,255,0.10);
      border-radius: 16px;
      background: rgba(0,0,0,0.22);
      padding: 14px;
    }
    .model-selector label {
      display: block;
      color: rgba(255,215,0,0.92);
      font-weight: 1000;
      margin-bottom: 8px;
      font-size: 0.95rem;
    }
    .model-selector select {
      width: 100%;
      padding: 8px;
      border-radius: 8px;
      border: 1px solid rgba(255,215,0,0.25);
      background: rgba(0,0,0,0.30);
      color: #fff;
      font-weight: 900;
      cursor: pointer;
    }
    .commands-panel {
      border: 1px solid rgba(255,255,255,0.10);
      border-radius: 16px;
      background: rgba(0,0,0,0.22);
      padding: 14px;
      max-height: 300px;
      overflow-y: auto;
    }
    .commands-title {
      color: rgba(255,215,0,0.92);
      font-weight: 1000;
      margin: 0 0 10px;
      font-size: 0.95rem;
    }
    .command-item {
      padding: 8px;
      margin-bottom: 8px;
      border-radius: 8px;
      border: 1px solid rgba(255,255,255,0.10);
      background: rgba(0,0,0,0.30);
      font-size: 0.85rem;
      color: var(--muted);
      font-weight: 900;
      word-break: break-all;
    }
    .command-item.create { border-left: 3px solid #2ecc71; }
    .command-item.edit { border-left: 3px solid #f39c12; }
    .command-item.delete { border-left: 3px solid #ff3b3b; }
    .approve-btn {
      width: 100%;
      padding: 10px;
      border-radius: 8px;
      border: none;
      background: linear-gradient(135deg, #2ecc71 0%, #27ae60 100%);
      color: #fff;
      font-weight: 1000;
      cursor: pointer;
      transition: all .16s ease;
    }
    .approve-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(46,204,113,0.3);
    }
    .approve-btn:disabled {
      opacity: 0.5;
      cursor: not-allowed;
      transform: none;
    }
    @media (max-width: 1024px) {
      .agent-wrapper {
        grid-template-columns: 1fr;
      }
      .sidebar {
        grid-column: 1;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
      }
    }
  </style>
</head>
<body>
  <div class="announcement">CreateAgent - AI-Powered Repository Assistant</div>
  
  <div class="container">
    <div class="topbar">
      <a href="/editor/<%= owner %>/<%= repo %>" style="display: flex; align-items: center; gap: 8px; color: rgba(255,215,0,0.92); text-decoration: none; font-weight: 1000;">
        ← Back
      </a>
      <a href="/auth/logout" class="icon-btn">🚪</a>
    </div>

    <div class="title-area">
      <h1 class="site-title">CreateAgent</h1>
      <p class="tagline">Your AI-powered coding assistant for <%= owner %>/<%= repo %></p>
    </div>

    <div class="agent-wrapper">
      <div class="chat-area">
        <div class="chat-messages" id="chatMessages"></div>
        <div class="chat-input-area">
          <input 
            type="text" 
            class="chat-input" 
            id="userInput" 
            placeholder="Ask CreateAgent to help..." 
            onkeypress="if(event.key==='Enter') sendMessage()"
          >
          <button class="chat-send" onclick="sendMessage()">Send</button>
        </div>
      </div>

      <div class="sidebar">
        <div class="model-selector">
          <label>AI Model</label>
          <select id="modelSelect">
            <option value="Divine Flex 1">Divine Flex 1</option>
            <option value="Divine Agent 1" selected>Divine Agent 1</option>
            <option value="Divine Flex 2">Divine Flex 2</option>
          </select>
        </div>

        <div class="commands-panel">
          <h3 class="commands-title">Pending Commands</h3>
          <div id="commandsList">
            <div style="color: var(--muted); font-size: 0.85rem; font-weight: 900;">No commands yet</div>
          </div>
          <button class="approve-btn" id="approveBtn" onclick="approveCommands()" disabled style="margin-top: 12px;">
            ✓ Approve All
          </button>
        </div>
      </div>
    </div>
  </div>

  <div class="site-footer">
    <p class="disclaimer">Always review and approve commands before they execute on your repository.</p>
  </div>

  <script>
    let pendingCommands = [];

    async function sendMessage() {
      const input = document.getElementById('userInput');
      const message = input.value.trim();

      if (!message) return;

      // Add user message to chat
      addMessage(message, 'user');
      input.value = '';

      try {
        const response = await fetch('/api/agent/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            message,
            model: document.getElementById('modelSelect').value,
            owner: '<%= owner %>',
            repo: '<%= repo %>',
          }),
        });

        const data = await response.json();
        addMessage(data.response, 'agent');

        if (data.commands && data.commands.length > 0) {
          pendingCommands = data.commands;
          updateCommandsList();
          document.getElementById('approveBtn').disabled = false;
        }
      } catch (error) {
        addMessage('Error communicating with CreateAgent', 'agent');
      }
    }

    function addMessage(text, sender) {
      const messagesDiv = document.getElementById('chatMessages');
      const messageEl = document.createElement('div');
      messageEl.className = `message ${sender}`;
      messageEl.textContent = text;
      messagesDiv.appendChild(messageEl);
      messagesDiv.scrollTop = messagesDiv.scrollHeight;
    }

    function updateCommandsList() {
      const list = document.getElementById('commandsList');
      list.innerHTML = '';

      pendingCommands.forEach((cmd, idx) => {
        const cmdEl = document.createElement('div');
        cmdEl.className = `command-item ${cmd.type}`;
        cmdEl.textContent = `[${cmd.type.toUpperCase()}] ${cmd.name}`;
        list.appendChild(cmdEl);
      });
    }

    async function approveCommands() {
      if (pendingCommands.length === 0) return;

      const btn = document.getElementById('approveBtn');
      btn.disabled = true;
      btn.textContent = 'Approving...';

      try {
        await fetch('/api/agent/approve', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            commands: pendingCommands,
            owner: '<%= owner %>',
            repo: '<%= repo %>',
          }),
        });

        addMessage('✓ Commands approved and applied to your repository!', 'agent');
        pendingCommands = [];
        document.getElementById('commandsList').innerHTML = '<div style="color: var(--muted); font-size: 0.85rem; font-weight: 900;">No commands yet</div>';
        btn.disabled = true;
        btn.textContent = '✓ Approve All';
      } catch (error) {
        addMessage('Error approving commands', 'agent');
        btn.disabled = false;
        btn.textContent = '✓ Approve All';
      }
    }
  </script>
</body>
</html>
